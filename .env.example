# =============================================================================
# .env.example — Open-Finance environment variables (local docker-compose run)
#
# Copy to .env and fill in real values:
#   cp .env.example .env
#
# NEVER commit .env — it is in .gitignore.
#
# For Railway (production): set these in the Railway dashboard, not here.
# =============================================================================

# =============================================================================
# REQUIRED
# =============================================================================

# JWT signing secret — minimum 32 characters of randomness.
# Generate: openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET_MIN_32_CHARS

# =============================================================================
# OPTIONAL — sensible defaults provided
# =============================================================================

# Master password for local SQLite encryption (leave blank to disable).
MASTER_PASSWORD=

# Open-Finance image tag to pull from GHCR (default: latest).
# Pin to a specific version for reproducible deployments, e.g. vlatest
OPEN_FINANCE_TAG=latest

# =============================================================================
# Host port for Ollama (change if 11434 conflicts)
OLLAMA_PORT=11434

# AI / Ollama
# =============================================================================

# AI provider: 'ollama' (local, default) or 'openai'
APPLICATION_AI_PROVIDER=ollama

# Ollama model — must be pulled first:
#   docker compose exec ollama ollama pull llama3.2:3b
APPLICATION_AI_OLLAMA_MODEL=llama3.2:3b

# OpenAI API key — only needed when APPLICATION_AI_PROVIDER=openai
APPLICATION_AI_OPENAI_API_KEY=

# OpenAI model — only needed when APPLICATION_AI_PROVIDER=openai
APPLICATION_AI_OPENAI_MODEL=gpt-5.2

# =============================================================================
# Market data (optional — only needed if you run a local yfinance wrapper)
# =============================================================================
# APPLICATION_MARKET_DATA_YAHOO_FINANCE_URL=http://localhost:5000

# =============================================================================
# Logging
# =============================================================================
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_ORG_OPENFINANCE=INFO

# =============================================================================
# CORS (set to the URL you use to access the app)
# =============================================================================
APPLICATION_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# =============================================================================
# SearXNG (optional web search for AI assistant)
# =============================================================================
# Host port for SearXNG (change if 8888 conflicts)
SEARXNG_PORT=8888
# APPLICATION_SEARXNG_BASE_URL=http://searxng:8080

# =============================================================================
# Application logo fetch (optional)
# =============================================================================
APPLICATION_LOGO_FETCH_ENABLED=true

# =============================================================================
# Application live demo (optional)
# =============================================================================
APPLICATION_LIVE_DEMO_ENABLED=true
